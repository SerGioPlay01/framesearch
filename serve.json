{
  "rewrites": [
    {
      "source": "/landing",
      "destination": "/landing.html"
    },
    {
      "source": "/video_id",
      "destination": "/video_id.html"
    },
    {
      "source": "/search_results",
      "destination": "/search_results.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/cookies",
      "destination": "/cookies.html"
    },
    {
      "source": "/license",
      "destination": "/license.html"
    },
    {
      "source": "/disclaimer",
      "destination": "/disclaimer.html"
    }
  ],
  "headers": [
    {
      "source": "**/*.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "**/*.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    }
  ]
}
